// ── HELPERS ───────────────────────────────────────────────
function fmt(n){if(!n||isNaN(n)||n===0)return'—';if(n>=100000)return'₹'+(n/100000).toFixed(1)+'L';if(n>=1000)return'₹'+(n/1000).toFixed(0)+'K';return'₹'+Math.round(n);}
function fdate(d){return d.slice(5).replace('-','/');}
const tipEl=document.getElementById('tip');
function showTip(e,h){tipEl.innerHTML=h;tipEl.style.display='block';tipEl.style.left=(e.clientX+12)+'px';tipEl.style.top=(e.clientY-30)+'px';}
function hideTip(){tipEl.style.display='none';}

// ── BAR CHART (vertical) ──────────────────────────────────
function barChart(id,labels,datasets,h){
  h=h||200;
  const el=document.getElementById(id);if(!el)return;
  const W=el.clientWidth||600;
  const P={t:8,r:10,b:48,l:55},cW=W-P.l-P.r,cH=h-P.t-P.b;
  const n=labels.length,ds=datasets.length;
  if(!n){el.innerHTML='';return;}
  const maxV=Math.max(...datasets.flatMap(d=>d.data).filter(v=>v>0),1);
  const bW=Math.min((cW/n)*0.8/ds,34);
  let s=`<svg width="${W}" height="${h}" xmlns="http://www.w3.org/2000/svg">`;
  for(let i=0;i<=4;i++){
    const y=P.t+cH-(i/4)*cH,v=maxV*i/4;
    s+=`<line x1="${P.l}" y1="${y|0}" x2="${P.l+cW}" y2="${y|0}" stroke="rgba(255,255,255,.06)" stroke-width="1"/>`;
    s+=`<text x="${P.l-4}" y="${(y+4)|0}" text-anchor="end" fill="#777" font-size="9" font-family="system-ui">${datasets[0]&&datasets[0].yf?datasets[0].yf(v):fmt(v)||'0'}</text>`;
  }
  datasets.forEach((d,di)=>{
    labels.forEach((lbl,i)=>{
      const v=d.data[i]||0,bH=Math.max((v/maxV)*cH,0);
      const x=P.l+i*(cW/n)+(cW/n-ds*bW)/2+di*bW,y=P.t+cH-bH;
      const tv=d.vf?d.vf(v):fmt(v);
      s+=`<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${bW.toFixed(1)}" height="${bH.toFixed(1)}" fill="${d.color}" rx="3" opacity=".88" style="cursor:pointer" onmouseenter="showTip(event,'<b>${lbl}</b><br>${d.label||''}: ${tv}')" onmouseleave="hideTip()"/>`;
    });
  });
  labels.forEach((lbl,i)=>{
    const x=(P.l+i*(cW/n)+(cW/n)/2)|0;
    s+=`<text x="${x}" y="${h-5}" text-anchor="end" fill="#aaa" font-size="9" font-family="system-ui" transform="rotate(-35,${x},${h-5})">${lbl}</text>`;
  });
  s+=`<line x1="${P.l}" y1="${P.t}" x2="${P.l}" y2="${P.t+cH}" stroke="#333" stroke-width="1"/>`;
  s+=`<line x1="${P.l}" y1="${P.t+cH}" x2="${P.l+cW}" y2="${P.t+cH}" stroke="#333" stroke-width="1"/>`;
  s+='</svg>';
  el.innerHTML=s;
}

// ── HORIZONTAL BAR CHART ──────────────────────────────────
function hbar(id,labels,values,colors,vf){
  const el=document.getElementById(id);if(!el)return;
  const W=el.clientWidth||400;
  const maxV=Math.max(...values,1),rowH=32,P={l:115,r:55,t:4};
  const H=labels.length*rowH+P.t*2;
  let s=`<svg width="${W}" height="${H}" xmlns="http://www.w3.org/2000/svg">`;
  labels.forEach((lbl,i)=>{
    const y=P.t+i*rowH,bW=((values[i]||0)/maxV)*(W-P.l-P.r);
    const col=Array.isArray(colors)?colors[i%colors.length]:colors;
    const tv=vf?vf(values[i]):''+Math.round(values[i]);
    s+=`<text x="${P.l-7}" y="${y+rowH/2+4}" text-anchor="end" fill="#aaa" font-size="10" font-family="system-ui">${lbl}</text>`;
    s+=`<rect x="${P.l}" y="${y+5}" width="${Math.max(bW,3).toFixed(1)}" height="${rowH-12}" fill="${col}" rx="3" opacity=".85" style="cursor:pointer" onmouseenter="showTip(event,'${lbl}: ${tv}')" onmouseleave="hideTip()"/>`;
    s+=`<text x="${P.l+bW+7}" y="${y+rowH/2+4}" fill="#ccc" font-size="10" font-family="system-ui">${tv}</text>`;
  });
  s+='</svg>';
  el.innerHTML=s;
}

// ── RENDER FUNCTIONS ──────────────────────────────────────
function renderOverview(){
  // Sales by date
  const byDate={};
  SALES.forEach(s=>{byDate[s.date]=(byDate[s.date]||0)+s.amt;});
  const dates=Object.keys(byDate).sort();
  barChart('ovSales',dates.map(d=>fdate(d)),[{label:'Sales',data:dates.map(d=>byDate[d]),color:'#22c55e',vf:fmt}],220);

  // Ads type
  const types={Inbound:ADS.filter(a=>a.type==='Inbound').length,CCBD:ADS.filter(a=>a.type==='CCBD').length};
  hbar('ovAdsType',Object.keys(types),Object.values(types),['#3b82f6','#7c3aed']);

  // Conversion
  const conv={'Converted':ADS.filter(a=>a.conv==='Yes').length,'Not Converted':ADS.filter(a=>a.conv==='No').length,'Pending':ADS.filter(a=>a.conv==='—').length};
  hbar('ovAdsConv',Object.keys(conv),Object.values(conv),['#22c55e','#ef4444','#888']);

  // Sales by POC
  const byPoc={};
  SALES.forEach(s=>{byPoc[s.poc]=(byPoc[s.poc]||0)+s.amt;});
  const pocs=Object.entries(byPoc).sort((a,b)=>b[1]-a[1]);
  hbar('ovPoc',pocs.map(p=>p[0]),pocs.map(p=>p[1]),['#a78bfa','#7c3aed','#6d28d9','#5b21b6'],fmt);
}

function renderMails(){
  document.getElementById('mailTable').innerHTML=MAILS.map(m=>`
    <div class="mail-row">
      <span style="color:#eee">${m.industry}</span>
      <span>${m.delivered}</span>
      <span>${m.opened} <span class="rate">${(m.opened/m.delivered*100).toFixed(1)}%</span></span>
      <span>${m.clicked} <span class="rate">${(m.clicked/m.delivered*100).toFixed(1)}%</span></span>
      <span>${m.responded} <span class="rate">${(m.responded/m.delivered*100).toFixed(1)}%</span></span>
    </div>`).join('');

  hbar('mailOpen',MAILS.map(m=>m.industry.slice(0,18)),MAILS.map(m=>+(m.opened/m.delivered*100).toFixed(1)),['#7c3aed','#6d28d9','#5b21b6','#4c1d95'],v=>v+'%');
  hbar('mailResp',MAILS.map(m=>m.industry.slice(0,18)),MAILS.map(m=>+(m.responded/m.delivered*100).toFixed(1)),['#22c55e','#16a34a','#15803d','#166534'],v=>v+'%');
}

function renderSales(){
  const byPoc={};
  SALES.forEach(s=>{byPoc[s.poc]=(byPoc[s.poc]||0)+s.amt;});
  const pocs=Object.entries(byPoc).sort((a,b)=>b[1]-a[1]);
  hbar('salesPoc',pocs.map(p=>p[0]),pocs.map(p=>p[1]),['#22c55e','#16a34a','#15803d','#166534'],fmt);

  const byDate={};
  SALES.forEach(s=>{byDate[s.date]=(byDate[s.date]||0)+s.amt;});
  const dates=Object.keys(byDate).sort();
  barChart('salesDate',dates.map(d=>fdate(d)),[{label:'Revenue',data:dates.map(d=>byDate[d]),color:'#22c55e',vf:fmt}],180);

  document.getElementById('salesTable').innerHTML=SALES.map(s=>`<tr>
    <td style="font-family:monospace;color:#a78bfa">${s.ref}</td>
    <td>${fdate(s.date)}</td>
    <td style="color:#fff">${s.client}</td>
    <td><span class="badge poc">${s.poc}</span></td>
    <td style="color:#888">${s.type}</td>
    <td style="text-align:right;font-family:monospace;color:#22c55e;font-weight:600">${fmt(s.amt)}</td>
  </tr>`).join('');
}

function renderAds(){
  document.getElementById('adsTable').innerHTML=ADS.map(a=>`<tr>
    <td>${fdate(a.date)}</td>
    <td style="color:#fff">${a.client}</td>
    <td><span class="badge ${a.type.toLowerCase()}">${a.type}</span></td>
    <td><span class="badge poc">${a.poc}</span></td>
    <td><span class="badge ${a.lead.toLowerCase()}">${a.lead}</span></td>
    <td><span class="badge ${a.conv==='Yes'?'yes':a.conv==='No'?'no':''}">${a.conv}</span></td>
    <td style="text-align:right;font-family:monospace;color:#22c55e">${a.val?fmt(a.val):'—'}</td>
  </tr>`).join('');
}

function renderInmails(){
  document.getElementById('inmailTable').innerHTML=INMAILS.map(m=>`<tr>
    <td style="color:#888">${m.n}</td>
    <td><span class="badge ${m.ind==='FM'?'inbound':'ccbd'}">${m.ind}</span></td>
    <td style="color:#fff">${m.company}</td>
    <td style="color:#aaa">${m.role}</td>
    <td style="color:#a78bfa">${m.poc}</td>
  </tr>`).join('');
}

function renderAll(){
  renderOverview();
  renderMails();
  renderSales();
  renderAds();
  renderInmails();
  document.getElementById('lu').textContent='Updated '+new Date().toLocaleTimeString();
}

// ── TABS ──────────────────────────────────────────────────
document.querySelectorAll('.tab').forEach(t=>t.addEventListener('click',()=>{
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('on'));
  document.querySelectorAll('.tp').forEach(x=>x.classList.remove('on'));
  t.classList.add('on');
  document.getElementById('tp-'+t.dataset.tab).classList.add('on');
  setTimeout(renderAll,30);
}));

document.querySelectorAll('[data-r]').forEach(b=>b.addEventListener('click',()=>{
  document.querySelectorAll('[data-r]').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');
}));

// ── BOOT ──────────────────────────────────────────────────
window.addEventListener('load',()=>{
  renderAll();
  if(SHEET_URL){
    fetch(SHEET_URL+'?t='+Date.now(),{cache:'no-store'})
      .then(r=>r.json())
      .then(()=>{document.getElementById('stxt').textContent='live · google sheets';renderAll();})
      .catch(()=>{document.getElementById('stxt').textContent='cached data';});
  }
  setInterval(renderAll,5*60*1000);
});
</script>
