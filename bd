<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>B2B Dashboard — Snackible</title>
<style>
:root{--bg:#0a0a0a;--s:#141414;--s2:#1c1c1c;--b:rgba(255,255,255,.07);--t:#fff;--m:#888;--ac:#7c3aed;--ac2:#a78bfa;--gr:#22c55e;--or:#f97316;--bl:#3b82f6;--re:#ef4444;--ye:#eab308;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--t);font-family:system-ui,sans-serif;}
.bar{border-bottom:1px solid var(--b);padding:13px 28px;display:flex;justify-content:space-between;align-items:center;background:var(--s);position:sticky;top:0;z-index:20;}
.logo{font-size:14px;font-weight:700;letter-spacing:.04em;}.logo em{color:var(--ac2);font-style:normal;}
.stl{font-size:11px;color:var(--m);display:flex;align-items:center;gap:6px;}
.dot{width:6px;height:6px;border-radius:50%;background:var(--gr);}
.wrap{padding:22px 28px;max-width:1400px;margin:0 auto;}
.ph{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:22px;flex-wrap:wrap;gap:12px;}
.pt{font-size:22px;font-weight:600;margin-bottom:3px;}
.ps{font-size:12px;color:var(--m);}
.ps em{color:var(--ac2);font-style:normal;}
.df{background:var(--s);border:1px solid var(--b);border-radius:10px;padding:9px 14px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.fl{font-size:10px;color:var(--m);text-transform:uppercase;letter-spacing:.07em;}
.di{background:var(--s2);border:1px solid var(--b);border-radius:6px;color:var(--t);font-size:12px;padding:5px 9px;outline:none;}
.di:focus{border-color:var(--ac2);}
.qb{background:transparent;border:1px solid var(--b);border-radius:6px;color:var(--m);font-size:11px;padding:5px 10px;cursor:pointer;font-family:system-ui;}
.qb:hover,.qb.on{background:var(--ac);border-color:var(--ac);color:#fff;font-weight:600;}
.mg{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:22px;}
.mc{background:var(--s);border:1px solid var(--b);border-radius:12px;padding:16px;position:relative;overflow:hidden;}
.mc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--ac);}
.mc.gn::before{background:var(--gr);}.mc.or::before{background:var(--or);}.mc.bl::before{background:var(--bl);}.mc.ye::before{background:var(--ye);}
.ml{font-size:10px;color:var(--m);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;}
.mv{font-size:22px;font-weight:600;font-family:monospace;color:#fff;}
.ms{font-size:11px;color:var(--m);margin-top:4px;}
.tabs{display:flex;border-bottom:1px solid var(--b);margin-bottom:20px;}
.tab{padding:10px 22px;font-size:13px;font-weight:500;color:var(--m);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;user-select:none;}
.tab:hover{color:var(--t);}.tab.on{color:var(--ac2);border-bottom-color:var(--ac2);}
.tp{display:none;}.tp.on{display:block;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px;}
.g1{margin-bottom:14px;}
.cc{background:var(--s);border:1px solid var(--b);border-radius:12px;padding:16px;}
.ch{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:6px;}
.ct{font-size:12px;font-weight:600;}
.cw{width:100%;}
.tip{position:fixed;background:#1a1a1a;border:1px solid #444;padding:5px 10px;border-radius:6px;font-size:11px;pointer-events:none;display:none;z-index:999;white-space:nowrap;}
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{text-align:left;padding:8px 10px;color:var(--m);font-weight:500;border-bottom:1px solid var(--b);font-size:10px;text-transform:uppercase;letter-spacing:.06em;}
.tbl td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.04);color:#ddd;vertical-align:middle;}
.tbl tr:hover td{background:rgba(255,255,255,.03);}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;}
.badge.yes{background:rgba(34,197,94,.15);color:#22c55e;}.badge.no{background:rgba(239,68,68,.12);color:#ef4444;}
.badge.warm{background:rgba(234,179,8,.12);color:#eab308;}.badge.cold{background:rgba(148,163,184,.1);color:#94a3b8;}
.badge.inbound{background:rgba(59,130,246,.12);color:#60a5fa;}.badge.ccbd{background:rgba(124,58,237,.15);color:#a78bfa;}
.badge.poc{background:rgba(124,58,237,.12);color:#c4b5fd;}
.funnel-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.funnel-lbl{font-size:11px;color:var(--m);width:88px;flex-shrink:0;text-align:right;}
.funnel-wrap{flex:1;background:rgba(255,255,255,.05);border-radius:4px;height:24px;overflow:hidden;}
.funnel-bar{height:100%;border-radius:4px;display:flex;align-items:center;padding-left:10px;font-size:11px;font-weight:600;color:#fff;white-space:nowrap;}
.funnel-pct{font-size:11px;color:var(--m);width:46px;text-align:right;flex-shrink:0;}
.fgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px;}
.fc{background:var(--s2);border-radius:10px;padding:14px;text-align:center;}
.fcv{font-size:26px;font-weight:600;font-family:monospace;}
.fcl{font-size:10px;color:var(--m);margin-top:3px;text-transform:uppercase;letter-spacing:.06em;}
.fcr{font-size:11px;color:var(--ac2);margin-top:3px;}
.mail-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1fr;gap:8px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;align-items:center;}
.mail-hdr{color:var(--m);font-size:10px;text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--b);padding-bottom:9px;margin-bottom:4px;}
.rate{display:inline-block;padding:1px 6px;border-radius:8px;font-size:10px;font-weight:600;background:rgba(124,58,237,.15);color:var(--ac2);}
.setup-box{background:var(--s);border:1px solid var(--b);border-radius:12px;padding:28px;text-align:center;color:var(--m);}
.setup-box h3{color:#fff;font-size:15px;margin-bottom:8px;}
.setup-box code{background:var(--s2);padding:3px 8px;border-radius:4px;font-size:12px;color:var(--ac2);}
@media(max-width:900px){.mg{grid-template-columns:repeat(3,1fr);}.g2,.g3{grid-template-columns:1fr;}.fgrid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.mg{grid-template-columns:repeat(2,1fr);}.wrap{padding:14px;}.ph{flex-direction:column;}}
</style>
</head>
